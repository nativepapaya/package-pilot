<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PackagePilot.App.Views.PackageRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:PackagePilot.App.Views"
    d:DesignHeight="72"
    d:DesignWidth="860"
    MinHeight="68"
    mc:Ignorable="d">

    <Border Style="{StaticResource PackagePilotRowCardStyle}">
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PackagePilotIconTileStyle}">
                <views:PackageIcon
                    FallbackGlyph="{x:Bind IconGlyph, Mode=OneWay}"
                    IconReference="{x:Bind IconReference, Mode=OneWay}"
                    IconUri="{x:Bind IconUri, Mode=OneWay}" />
            </Border>

            <Grid
                Grid.Column="1"
                VerticalAlignment="Center"
                RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock
                        FontFamily="{StaticResource PackagePilotContentFont}"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        Text="{x:Bind PackageName, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        ToolTipService.ToolTip="{x:Bind PackageId, Mode=OneWay}" />
                    <Border
                        x:Name="StateBadge"
                        Padding="7,2"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="10"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon
                                x:Name="StateBadgeIcon"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="10"
                                Glyph="{x:Bind StateGlyph, Mode=OneWay}" />
                            <TextBlock
                                x:Name="StateBadgeText"
                                FontSize="11"
                                Text="{x:Bind Status, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="7">
                    <TextBlock Style="{StaticResource PackagePilotCaptionStyle}" Text="{x:Bind Publisher, Mode=OneWay}" />
                    <Border
                        x:Name="SourceBadge"
                        Padding="6,1"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="8">
                        <TextBlock
                            x:Name="SourceText"
                            Style="{StaticResource PackagePilotCaptionStyle}"
                            Text="{x:Bind Source, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis" />
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel
                x:Name="MetadataPanel"
                Grid.Column="2"
                MinWidth="120"
                VerticalAlignment="Center"
                Spacing="2">
                <TextBlock
                    HorizontalAlignment="Right"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    Text="{x:Bind Version, Mode=OneWay}" />
                <TextBlock
                    x:Name="PlainStatusText"
                    HorizontalAlignment="Right"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind Status, Mode=OneWay}" />
            </StackPanel>

            <Button
                x:Name="ActionButton"
                Grid.Column="3"
                MinWidth="86"
                VerticalAlignment="Center"
                AutomationProperties.Name="{x:Bind ActionAutomationName}"
                Click="OnActionClick"
                Content="{x:Bind ActionLabel, Mode=OneWay}"
                IsEnabled="{x:Bind IsActionEnabled, Mode=OneWay}" />

            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup>
                    <VisualState x:Name="Compact">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="MetadataPanel.Visibility" Value="Collapsed" />
                            <Setter Target="SourceBadge.Visibility" Value="Collapsed" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Comfortable">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="760" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="MetadataPanel.Visibility" Value="Visible" />
                            <Setter Target="SourceBadge.Visibility" Value="Visible" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
                <VisualStateGroup>
                    <VisualState x:Name="NeutralState" />
                    <VisualState x:Name="PositiveState">
                        <VisualState.Setters>
                            <Setter Target="StateBadge.Background" Value="{ThemeResource PackagePilotSuccessSoftBrush}" />
                            <Setter Target="StateBadge.BorderBrush" Value="{ThemeResource PackagePilotSuccessBrush}" />
                            <Setter Target="StateBadgeIcon.Foreground" Value="{ThemeResource PackagePilotSuccessBrush}" />
                            <Setter Target="StateBadgeText.Foreground" Value="{ThemeResource PackagePilotSuccessBrush}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
        </Grid>
    </Border>
</UserControl>
