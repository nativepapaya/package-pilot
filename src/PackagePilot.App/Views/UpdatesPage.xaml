<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PackagePilot.App.Views.UpdatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:PackagePilot.App.Views"
    Background="{ThemeResource PackagePilotPageBrush}">

    <Page.Resources>
        <DataTemplate x:Key="UpdatePackageTemplate" x:DataType="views:PackageListItem">
            <views:PackageRow
                Margin="0,0,0,8"
                ActionInvoked="OnPackageActionInvoked"
                ActionLabel="{x:Bind ActionLabel}"
                IconGlyph="{x:Bind IconGlyph}"
                IconUri="{x:Bind IconUri}"
                PackageId="{x:Bind PackageId}"
                PackageName="{x:Bind Name}"
                Publisher="{x:Bind Publisher}"
                Source="{x:Bind Source}"
                Status="{x:Bind Status}"
                Tag="{x:Bind PackageId}"
                Version="{x:Bind VersionLabel}" />
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="Root" Padding="24,20,24,24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock AutomationProperties.HeadingLevel="Level1" Style="{StaticResource PackagePilotPageTitleStyle}" Text="Updates" />
                <TextBlock Style="{StaticResource PackagePilotSubtitleStyle}" Text="Keep installed apps current with a calm, sequential update queue." />
            </StackPanel>
            <Button
                Grid.Column="1"
                Style="{StaticResource PackagePilotIconButtonStyle}"
                AutomationProperties.Name="Check for updates"
                Click="OnRefreshClick"
                ToolTipService.ToolTip="Check for updates (Ctrl+R)">
                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72C;" />
            </Button>
        </Grid>

        <InfoBar
            x:Name="StatusBanner"
            Grid.Row="1"
            IsClosable="True"
            IsOpen="False"
            Severity="Informational" />

        <Border Grid.Row="2" Style="{StaticResource PackagePilotSubtleCardStyle}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Spacing="3">
                    <TextBlock x:Name="UpdateSummaryText" FontWeight="SemiBold" Text="No updates loaded" />
                    <TextBlock
                        Style="{StaticResource PackagePilotCaptionStyle}"
                        Text="Selected updates are reviewed first, then installed one at a time." />
                </StackPanel>
                <Button
                    x:Name="ReviewButton"
                    Grid.Column="1"
                    MinWidth="150"
                    AutomationProperties.Name="Review selected updates"
                    Click="OnReviewSelectedClick"
                    Content="Review selected"
                    IsEnabled="False"
                    Style="{StaticResource AccentButtonStyle}" />
            </Grid>
        </Border>

        <Grid Grid.Row="3" RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <CheckBox
                x:Name="SelectAllBox"
                AutomationProperties.Name="Select all available updates"
                Checked="OnSelectAllChanged"
                Content="Select all"
                IsEnabled="False"
                Unchecked="OnSelectAllChanged" />

            <Grid Grid.Row="1">
                <ListView
                    x:Name="UpdatesList"
                    Style="{StaticResource PackagePilotListViewStyle}"
                    AutomationProperties.Name="Available package updates"
                    ItemTemplate="{StaticResource UpdatePackageTemplate}"
                    ItemsSource="{x:Bind AvailableUpdates}"
                    SelectionChanged="OnSelectionChanged"
                    SelectionMode="Multiple"
                    Visibility="Collapsed">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <StackPanel
                    x:Name="EmptyState"
                    MaxWidth="460"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10">
                    <Border
                        Width="64"
                        Height="64"
                        HorizontalAlignment="Center"
                        Background="{ThemeResource PackagePilotSuccessSoftBrush}"
                        CornerRadius="18">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="28"
                            Foreground="{ThemeResource PackagePilotSuccessBrush}"
                            Glyph="&#xE73E;" />
                    </Border>
                    <TextBlock HorizontalAlignment="Center" Style="{StaticResource PackagePilotSectionTitleStyle}" Text="You're up to date" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource PackagePilotSubtitleStyle}"
                        Text="Package Pilot will list updates here when WinGet finds newer versions."
                        TextAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="Root.Padding" Value="16,16,16,20" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="900" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="Root.Padding" Value="32,24,32,32" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</Page>
