<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PackagePilot.App.Views.SourcesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:PackagePilot.App.Views"
    Background="{ThemeResource PackagePilotPageBrush}">

    <Page.Resources>
        <DataTemplate x:Key="SourceTemplate" x:DataType="views:SourceManagementListItem">
            <Border Style="{StaticResource PackagePilotRowCardStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="3">
                        <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                        <TextBlock Style="{StaticResource PackagePilotCaptionStyle}" Text="{x:Bind Location}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Style="{StaticResource PackagePilotCaptionStyle}" Text="{x:Bind AgreementSummary}" />
                    </StackPanel>
                    <Border Grid.Column="1" VerticalAlignment="Top" Style="{StaticResource PackagePilotPillStyle}">
                        <TextBlock Style="{StaticResource PackagePilotCaptionStyle}" Text="{x:Bind Status}" />
                    </Border>
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
                        <Button Content="Refresh" IsEnabled="{x:Bind CanRefresh}" Tag="{x:Bind Id}" Click="OnRefreshSourceClick" />
                        <Button Content="{x:Bind ExplicitActionLabel}" IsEnabled="{x:Bind CanEditExplicit}" Tag="{x:Bind Id}" Click="OnToggleExplicitClick" />
                        <Button AutomationProperties.Name="More source actions" Content="More">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem
                                        Click="OnResetClick"
                                        IsEnabled="{x:Bind CanReset}"
                                        Tag="{x:Bind Id}"
                                        Text="Repair this source" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem
                                        Click="OnRemoveClick"
                                        IsEnabled="{x:Bind CanRemove}"
                                        Tag="{x:Bind Id}"
                                        Text="Remove source" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                    <TextBlock
                        Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Style="{StaticResource PackagePilotCaptionStyle}"
                        Text="{x:Bind LastUpdated}" />
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="Root" Padding="24,20,24,24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock AutomationProperties.HeadingLevel="Level1" Style="{StaticResource PackagePilotPageTitleStyle}" Text="Sources" />
                <TextBlock x:Name="CapabilityText" Style="{StaticResource PackagePilotSubtitleStyle}" Text="Review and manage supported WinGet sources." />
            </StackPanel>
            <ProgressRing x:Name="LoadingRing" Grid.Column="1" Width="22" Height="22" IsActive="False" Visibility="Collapsed" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button x:Name="RefreshButton" Content="Refresh" Click="OnRefreshClick" />
                <Button x:Name="AddButton" Content="Add source" Click="OnAddClick" />
            </StackPanel>
        </Grid>

        <InfoBar x:Name="StatusBanner" Grid.Row="1" IsClosable="True" IsOpen="False" />

        <Grid Grid.Row="2">
            <ListView
                x:Name="SourceList"
                Style="{StaticResource PackagePilotListViewStyle}"
                AutomationProperties.Name="Configured package sources"
                ItemTemplate="{StaticResource SourceTemplate}"
                ItemsSource="{x:Bind Sources}"
                SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style BasedOn="{StaticResource PackagePilotListItemStyle}" TargetType="ListViewItem" />
                </ListView.ItemContainerStyle>
            </ListView>
            <StackPanel x:Name="EmptyState" MaxWidth="440" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                <Border Width="64" Height="64" HorizontalAlignment="Center" Background="{ThemeResource AccentFillColorSecondaryBrush}" CornerRadius="18">
                    <FontIcon HorizontalAlignment="Center" FontSize="28" Glyph="&#xE774;" />
                </Border>
                <TextBlock HorizontalAlignment="Center" Style="{StaticResource PackagePilotSectionTitleStyle}" Text="No sources loaded" />
                <TextBlock Style="{StaticResource PackagePilotSubtitleStyle}" Text="Refresh to read the sources configured for WinGet." TextAlignment="Center" />
            </StackPanel>
            <TextBlock x:Name="CountText" HorizontalAlignment="Right" VerticalAlignment="Bottom" Style="{StaticResource PackagePilotCaptionStyle}" Text="No sources loaded" />
        </Grid>
    </Grid>
</Page>
