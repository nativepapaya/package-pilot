<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PackagePilot.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:PackagePilot.App.Views"
    Background="{ThemeResource PackagePilotPageBrush}">

    <Page.Resources>
        <DataTemplate x:Key="SourceTemplate" x:DataType="views:SourceHealthItem">
            <Border Margin="0,0,0,8" Style="{StaticResource PackagePilotSubtleCardStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="40" Height="40" Style="{StaticResource PackagePilotIconTileStyle}">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE774;" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                        <TextBlock Style="{StaticResource PackagePilotCaptionStyle}" Text="{x:Bind Identifier}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Style="{StaticResource PackagePilotCaptionStyle}" Text="{x:Bind Detail}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource PackagePilotPillStyle}">
                        <TextBlock Style="{StaticResource PackagePilotCaptionStyle}" Text="{x:Bind Status}" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="Root" Padding="24,20,24,24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="4">
            <TextBlock AutomationProperties.HeadingLevel="Level1" Style="{StaticResource PackagePilotPageTitleStyle}" Text="Settings" />
            <TextBlock Style="{StaticResource PackagePilotSubtitleStyle}" Text="Choose how Package Pilot looks and prepares installs." />
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="860" HorizontalAlignment="Left" Spacing="20">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource PackagePilotSectionTitleStyle}" Text="Appearance" />
                    <Border Style="{StaticResource PackagePilotCardStyle}">
                        <StackPanel Spacing="18">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="App theme" />
                                    <TextBlock Style="{StaticResource PackagePilotCaptionStyle}" Text="Follow Windows, or keep Package Pilot light or dark." />
                                </StackPanel>
                                <ComboBox
                                    x:Name="ThemeBox"
                                    Grid.Column="1"
                                    MinWidth="150"
                                    AutomationProperties.Name="App theme"
                                    SelectedIndex="0"
                                    SelectionChanged="OnThemeChanged">
                                    <ComboBoxItem Content="Use system setting" Tag="system" />
                                    <ComboBoxItem Content="Light" Tag="light" />
                                    <ComboBoxItem Content="Dark" Tag="dark" />
                                </ComboBox>
                            </Grid>
                            <Rectangle Height="1" Fill="{ThemeResource PackagePilotStrokeBrush}" />
                            <ToggleSwitch
                                x:Name="ReduceMotionToggle"
                                AutomationProperties.Name="Reduce motion"
                                Header="Reduce motion"
                                OffContent="Use standard transitions"
                                OnContent="Use fewer transitions"
                                Toggled="OnReduceMotionToggled" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource PackagePilotSectionTitleStyle}" Text="Install preferences" />
                    <Border Style="{StaticResource PackagePilotCardStyle}">
                        <StackPanel Spacing="18">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="Default scope" />
                                    <TextBlock Style="{StaticResource PackagePilotCaptionStyle}" Text="Unavailable choices are ignored and left to the installer." />
                                </StackPanel>
                                <ComboBox
                                    x:Name="ScopeBox"
                                    Grid.Column="1"
                                    MinWidth="150"
                                    AutomationProperties.Name="Default install scope"
                                    SelectedIndex="0"
                                    SelectionChanged="OnScopeChanged">
                                    <ComboBoxItem Content="Installer default" Tag="default" />
                                    <ComboBoxItem Content="Current user" Tag="user" />
                                    <ComboBoxItem Content="All users" Tag="machine" />
                                </ComboBox>
                            </Grid>
                            <Rectangle Height="1" Fill="{ThemeResource PackagePilotStrokeBrush}" />
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="Preferred architecture" />
                                    <TextBlock Style="{StaticResource PackagePilotCaptionStyle}" Text="Automatic is recommended for this x64 PC." />
                                </StackPanel>
                                <ComboBox
                                    x:Name="ArchitectureBox"
                                    Grid.Column="1"
                                    MinWidth="150"
                                    AutomationProperties.Name="Preferred package architecture"
                                    SelectedIndex="0"
                                    SelectionChanged="OnArchitectureChanged">
                                    <ComboBoxItem Content="Automatic" Tag="auto" />
                                    <ComboBoxItem Content="x64" Tag="x64" />
                                    <ComboBoxItem Content="x86" Tag="x86" />
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource PackagePilotSectionTitleStyle}" Text="Sources" />
                    <InfoBar
                        IsClosable="False"
                        IsOpen="True"
                        Message="Source health is summarized here. Use the Sources destination for supported refresh and administration actions."
                        Severity="Informational"
                        Title="Source summary" />
                    <ListView
                        Style="{StaticResource PackagePilotListViewStyle}"
                        AutomationProperties.Name="Configured WinGet sources"
                        IsItemClickEnabled="False"
                        ItemTemplate="{StaticResource SourceTemplate}"
                        ItemsSource="{x:Bind Sources}"
                        SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource PackagePilotSectionTitleStyle}" Text="Update monitoring" />
                    <Border Style="{StaticResource PackagePilotCardStyle}">
                        <StackPanel Spacing="14">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="Check for application updates" />
                                    <TextBlock
                                        Style="{StaticResource PackagePilotCaptionStyle}"
                                        Text="Background checks are read-only and run when Windows allows. Installs and updates always wait for your review."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <ComboBox
                                    x:Name="UpdateCadenceBox"
                                    Grid.Column="1"
                                    MinWidth="160"
                                    AutomationProperties.Name="Application update check frequency"
                                    SelectedIndex="0"
                                    SelectionChanged="OnUpdateCadenceChanged">
                                    <ComboBoxItem Content="Daily" Tag="daily" />
                                    <ComboBoxItem Content="Every 6 hours" Tag="sixHours" />
                                    <ComboBoxItem Content="Manual" Tag="manual" />
                                </ComboBox>
                            </Grid>
                            <InfoBar
                                x:Name="BackgroundMonitoringInfoBar"
                                AutomationProperties.LiveSetting="Polite"
                                IsClosable="True"
                                IsOpen="False"
                                Severity="Informational" />
                            <TextBlock
                                x:Name="BackgroundStatusText"
                                Style="{StaticResource PackagePilotCaptionStyle}"
                                Text="Background status has not been loaded."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource PackagePilotSectionTitleStyle}" Text="Privacy and diagnostics" />
                    <Border Style="{StaticResource PackagePilotCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="Local by design" />
                            <TextBlock
                                Style="{StaticResource PackagePilotSubtitleStyle}"
                                Text="Package Pilot does not collect telemetry. Preferences and the 100 most recent operation results stay on this PC. WinGet sources and installers may have their own network and privacy behavior." />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource PackagePilotSectionTitleStyle}" Text="Package Pilot updates" />
                    <Border Style="{StaticResource PackagePilotCardStyle}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="8">
                                <StackPanel Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="Automatic updates" />
                                    <TextBlock x:Name="VersionText" Style="{StaticResource PackagePilotCaptionStyle}" Text="Version unavailable" />
                                    <TextBlock
                                        Style="{StaticResource PackagePilotSubtitleStyle}"
                                        Text="Windows checks the Package Pilot release feed quietly about once a day and in the background."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <InfoBar
                                    x:Name="UpdateInfoBar"
                                    AutomationProperties.LiveSetting="Polite"
                                    IsClosable="False"
                                    IsOpen="False"
                                    Severity="Informational" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Left" Spacing="8">
                                <Button
                                    x:Name="CheckForUpdatesButton"
                                    AutomationProperties.Name="Check for Package Pilot updates"
                                    Click="OnCheckForUpdatesClick"
                                    Content="Check for updates" />
                                <HyperlinkButton
                                    AutomationProperties.Name="Download Package Pilot update installer"
                                    Content="Get update installer"
                                    NavigateUri="https://github.com/nativepapaya/package-pilot/releases/latest/download/PackagePilot.appinstaller" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource PackagePilotSectionTitleStyle}" Text="About" />
                    <Border Style="{StaticResource PackagePilotCardStyle}">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="48" Height="48" Style="{StaticResource PackagePilotIconTileStyle}">
                                <FontIcon FontFamily="Segoe Fluent Icons" FontSize="22" Glyph="&#xE7C3;" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="Package Pilot" />
                                <TextBlock x:Name="CapabilityText" Style="{StaticResource PackagePilotCaptionStyle}" Text="Checking Windows integration capabilities…" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="Root.Padding" Value="16,16,16,20" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="900" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="Root.Padding" Value="32,24,32,32" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</Page>
