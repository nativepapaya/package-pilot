<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PackagePilot.App.Views.InstalledPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:PackagePilot.App.Views"
    Background="{ThemeResource PackagePilotPageBrush}">

    <Page.Resources>
        <DataTemplate x:Key="InstalledPackageTemplate" x:DataType="views:PackageListItem">
            <views:PackageRow
                ActionInvoked="OnPackageActionInvoked"
                ActionLabel="{x:Bind ActionLabel}"
                IconGlyph="{x:Bind IconGlyph, Mode=OneWay}"
                IconReference="{x:Bind IconReference, Mode=OneWay}"
                IconUri="{x:Bind IconUri, Mode=OneWay}"
                IsActionEnabled="{x:Bind IsActionEnabled}"
                IsPositiveState="{x:Bind IsPositiveState, Mode=OneWay}"
                PackageId="{x:Bind PackageId}"
                PackageName="{x:Bind Name, Mode=OneWay}"
                Publisher="{x:Bind Publisher, Mode=OneWay}"
                Source="{x:Bind Source}"
                StateGlyph="{x:Bind StateGlyph, Mode=OneWay}"
                Status="{x:Bind Status}"
                Tag="{x:Bind PackageId}"
                Version="{x:Bind VersionLabel}" />
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="Root" Padding="24,20,24,24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock AutomationProperties.HeadingLevel="Level1" Style="{StaticResource PackagePilotPageTitleStyle}" Text="Installed" />
                <TextBlock Style="{StaticResource PackagePilotSubtitleStyle}" Text="Review WinGet, Store/MSIX, and visible legacy applications on this PC." />
            </StackPanel>
            <Button
                Grid.Column="1"
                Style="{StaticResource PackagePilotIconButtonStyle}"
                AutomationProperties.Name="Refresh installed packages"
                Click="OnRefreshClick"
                ToolTipService.ToolTip="Refresh (Ctrl+R)">
                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72C;" />
            </Button>
        </Grid>

        <InfoBar
            x:Name="StatusBanner"
            Grid.Row="1"
            IsClosable="True"
            IsOpen="False"
            Severity="Informational" />

        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="DetailsColumn" Width="0" />
            </Grid.ColumnDefinitions>
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <AutoSuggestBox
                        x:Name="InstalledSearchBox"
                        AutomationProperties.Name="Filter installed packages"
                        PlaceholderText="Filter installed apps"
                        QueryIcon="Find">
                        <AutoSuggestBox.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="OnFocusSearchInvoked" />
                        </AutoSuggestBox.KeyboardAccelerators>
                    </AutoSuggestBox>
                    <ComboBox
                        x:Name="ProviderFilterBox"
                        Grid.Column="1"
                        MinWidth="130"
                        AutomationProperties.Name="Filter installed packages by provider"
                        Header="Provider">
                        <ComboBoxItem Content="All providers" Tag="all" />
                        <ComboBoxItem Content="WinGet" Tag="winget" />
                        <ComboBoxItem Content="Windows" Tag="windows" />
                        <ComboBoxItem Content="Registry" Tag="registry" />
                    </ComboBox>
                    <ComboBox
                        x:Name="TypeFilterBox"
                        Grid.Column="2"
                        MinWidth="125"
                        AutomationProperties.Name="Filter installed packages by type"
                        Header="Type">
                        <ComboBoxItem Content="All types" Tag="all" />
                        <ComboBoxItem Content="Store apps" Tag="store" />
                        <ComboBoxItem Content="MSIX" Tag="msix" />
                        <ComboBoxItem Content="Legacy" Tag="legacy" />
                    </ComboBox>
                    <ComboBox
                        x:Name="SortBox"
                        Grid.Column="3"
                        MinWidth="130"
                        AutomationProperties.Name="Sort installed packages"
                        Header="Sort by">
                        <ComboBoxItem Content="Name" Tag="name" />
                        <ComboBoxItem Content="Publisher" Tag="publisher" />
                        <ComboBoxItem Content="Version" Tag="version" />
                    </ComboBox>
                </Grid>

                <Grid Grid.Row="1">
                    <ListView
                        x:Name="InstalledList"
                        Style="{StaticResource PackagePilotListViewStyle}"
                        AutomationProperties.Name="Installed packages"
                        ItemTemplate="{StaticResource InstalledPackageTemplate}"
                        SelectionChanged="OnPackageSelectionChanged"
                        Visibility="Collapsed">
                        <ListView.ItemContainerStyle>
                            <Style BasedOn="{StaticResource PackagePilotListItemStyle}" TargetType="ListViewItem" />
                        </ListView.ItemContainerStyle>
                    </ListView>

                    <StackPanel
                        x:Name="EmptyState"
                        MaxWidth="460"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10">
                        <Border
                            Width="64"
                            Height="64"
                            HorizontalAlignment="Center"
                            Background="{ThemeResource AccentFillColorSecondaryBrush}"
                            CornerRadius="18">
                            <FontIcon FontFamily="Segoe Fluent Icons" FontSize="28" Glyph="&#xE74C;" />
                        </Border>
                        <TextBlock
                            x:Name="EmptyStateTitle"
                            HorizontalAlignment="Center"
                            Style="{StaticResource PackagePilotSectionTitleStyle}"
                            Text="No matching apps" />
                        <TextBlock
                            x:Name="EmptyStateDescription"
                            HorizontalAlignment="Center"
                            Style="{StaticResource PackagePilotSubtitleStyle}"
                            Text="Refresh to scan installed software, or clear the filter to see all detected packages."
                            TextAlignment="Center" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="PackageCountText"
                        VerticalAlignment="Center"
                        Style="{StaticResource PackagePilotCaptionStyle}"
                        AutomationProperties.LiveSetting="Polite"
                        TextTrimming="CharacterEllipsis"
                        Text="No packages loaded" />
                    <ToggleButton
                        x:Name="ShowWindowsManagedToggle"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Show Windows-managed apps"
                        Click="OnShowWindowsManagedClick"
                        Content="Show Windows-managed apps"
                        ToolTipService.ToolTip="Include apps that Package Pilot can only hand off to Windows or Microsoft Store."
                        Visibility="Collapsed" />
                </Grid>
            </Grid>

            <views:PackageDetailsPane
                x:Name="DetailsPane"
                Grid.Column="1"
                MinWidth="340"
                CloseRequested="OnDetailsCloseRequested"
                PrimaryActionInvoked="OnDetailsPrimaryActionInvoked"
                Visibility="Collapsed" />

            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup>
                    <VisualState x:Name="Narrow">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="Root.Padding" Value="16,16,16,20" />
                            <Setter Target="TypeFilterBox.Visibility" Value="Collapsed" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Wide">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="900" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="Root.Padding" Value="32,24,32,32" />
                            <Setter Target="TypeFilterBox.Visibility" Value="Visible" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
        </Grid>
    </Grid>
</Page>
