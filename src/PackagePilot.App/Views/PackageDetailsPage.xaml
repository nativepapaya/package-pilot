<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PackagePilot.App.Views.PackageDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:PackagePilot.App.Views"
    Background="{ThemeResource PackagePilotPageBrush}">

    <Grid Padding="24,20,24,24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Button
            Style="{StaticResource PackagePilotIconButtonStyle}"
            AutomationProperties.Name="Go back"
            Click="OnBackClick"
            ToolTipService.ToolTip="Back">
            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72B;" />
        </Button>
        <views:PackageDetailsPane
            x:Name="DetailsPane"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            CloseRequested="OnCloseRequested"
            PrimaryActionInvoked="OnPrimaryActionInvoked" />
    </Grid>
</Page>
