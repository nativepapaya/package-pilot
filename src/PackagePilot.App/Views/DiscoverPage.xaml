<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PackagePilot.App.Views.DiscoverPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:PackagePilot.App.Views"
    Background="{ThemeResource PackagePilotPageBrush}">

    <Page.Resources>
        <DataTemplate x:Key="PackageTemplate" x:DataType="views:PackageListItem">
            <views:PackageRow
                ActionInvoked="OnPackageActionInvoked"
                ActionLabel="{x:Bind ActionLabel, Mode=OneWay}"
                IconGlyph="{x:Bind IconGlyph, Mode=OneWay}"
                IconReference="{x:Bind IconReference, Mode=OneWay}"
                IconUri="{x:Bind IconUri, Mode=OneWay}"
                IsActionEnabled="{x:Bind IsActionEnabled, Mode=OneWay}"
                IsPositiveState="{x:Bind IsPositiveState, Mode=OneWay}"
                PackageId="{x:Bind PackageId}"
                PackageName="{x:Bind Name, Mode=OneWay}"
                Publisher="{x:Bind Publisher, Mode=OneWay}"
                Source="{x:Bind Source}"
                StateGlyph="{x:Bind StateGlyph, Mode=OneWay}"
                Status="{x:Bind Status, Mode=OneWay}"
                Tag="{x:Bind WingetPackage}"
                Version="{x:Bind VersionLabel}" />
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="Root" Padding="24,20,24,24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock AutomationProperties.HeadingLevel="Level1" Style="{StaticResource PackagePilotPageTitleStyle}" Text="Discover" />
                <TextBlock Style="{StaticResource PackagePilotSubtitleStyle}" Text="Find trusted apps from your configured WinGet sources." />
            </StackPanel>
            <Button
                Grid.Column="1"
                Style="{StaticResource PackagePilotIconButtonStyle}"
                AutomationProperties.Name="Refresh package catalogs"
                Click="OnRefreshClick"
                KeyboardAcceleratorPlacementMode="Hidden"
                ToolTipService.ToolTip="Refresh (Ctrl+R)">
                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72C;" />
            </Button>
        </Grid>

        <InfoBar
            x:Name="StatusBanner"
            Grid.Row="1"
            IsClosable="True"
            IsOpen="False"
            Severity="Informational" />

        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="DetailsColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <AutoSuggestBox
                        x:Name="PackageSearchBox"
                        AutomationProperties.Name="Search packages"
                        PlaceholderText="Search apps, publishers, or package IDs"
                        QuerySubmitted="OnQuerySubmitted"
                        TextChanged="OnSearchTextChanged">
                        <AutoSuggestBox.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="OnFocusSearchInvoked" />
                        </AutoSuggestBox.KeyboardAccelerators>
                    </AutoSuggestBox>
                    <Button
                        Grid.Column="1"
                        Style="{StaticResource PackagePilotIconButtonStyle}"
                        AutomationProperties.Name="Search packages now"
                        Click="OnSearchClick"
                        ToolTipService.ToolTip="Search">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE721;" />
                    </Button>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Style="{StaticResource PackagePilotPillStyle}">
                            <TextBlock Style="{StaticResource PackagePilotCaptionStyle}" Text="Configured sources" />
                        </Border>
                        <Border Style="{StaticResource PackagePilotPillStyle}">
                            <TextBlock Style="{StaticResource PackagePilotCaptionStyle}" Text="Up to 100 results" />
                        </Border>
                    </StackPanel>
                </Grid>

                <ProgressBar
                    x:Name="LoadingBar"
                    Grid.Row="2"
                    Height="3"
                    AutomationProperties.Name="Searching packages"
                    IsIndeterminate="True"
                    Visibility="Collapsed" />

                <Grid Grid.Row="3">
                    <ListView
                        x:Name="ResultsList"
                        Style="{StaticResource PackagePilotListViewStyle}"
                        AutomationProperties.Name="Package search results"
                        ItemTemplate="{StaticResource PackageTemplate}"
                        ItemsSource="{x:Bind Results}"
                        SelectionChanged="OnPackageSelectionChanged"
                        Visibility="Collapsed">
                        <ListView.ItemContainerStyle>
                            <Style BasedOn="{StaticResource PackagePilotListItemStyle}" TargetType="ListViewItem" />
                        </ListView.ItemContainerStyle>
                    </ListView>

                    <StackPanel
                        x:Name="EmptyState"
                        MaxWidth="480"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Search WinGet packages"
                        Spacing="10">
                        <Border
                            Width="64"
                            Height="64"
                            HorizontalAlignment="Center"
                            Background="{ThemeResource AccentFillColorSecondaryBrush}"
                            CornerRadius="18">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="28"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Glyph="&#xE721;" />
                        </Border>
                        <TextBlock
                            HorizontalAlignment="Center"
                            Style="{StaticResource PackagePilotSectionTitleStyle}"
                            Text="Search the WinGet catalog" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Style="{StaticResource PackagePilotSubtitleStyle}"
                            Text="Type a name, publisher, or exact package ID. Results come directly from the sources configured on this PC."
                            TextAlignment="Center" />
                    </StackPanel>
                </Grid>

                <TextBlock
                    x:Name="ResultCountText"
                    Grid.Row="4"
                    Style="{StaticResource PackagePilotCaptionStyle}"
                    AutomationProperties.LiveSetting="Polite"
                    Text="No results loaded" />
            </Grid>

            <views:PackageDetailsPane
                x:Name="DetailsPane"
                Grid.Column="1"
                MinWidth="340"
                CloseRequested="OnDetailsCloseRequested"
                PrimaryActionInvoked="OnDetailsPrimaryActionInvoked"
                Visibility="Collapsed" />

            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup>
                    <VisualState x:Name="Narrow">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="Root.Padding" Value="16,16,16,20" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Wide">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="900" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="Root.Padding" Value="32,24,32,32" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
        </Grid>
    </Grid>
</Page>
