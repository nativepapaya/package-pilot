<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="PackagePilotPageBrush" Color="Transparent" />
            <SolidColorBrush x:Key="PackagePilotSurfaceBrush" Color="#CC202127" />
            <SolidColorBrush x:Key="PackagePilotSurfaceSecondaryBrush" Color="#B32A2B32" />
            <SolidColorBrush x:Key="PackagePilotSurfaceTertiaryBrush" Color="#8035363E" />
            <SolidColorBrush x:Key="PackagePilotStrokeBrush" Color="#27FFFFFF" />
            <SolidColorBrush x:Key="PackagePilotStrokeStrongBrush" Color="#42FFFFFF" />
            <SolidColorBrush x:Key="PackagePilotTextPrimaryBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="PackagePilotTextSecondaryBrush" Color="#B8FFFFFF" />
            <SolidColorBrush x:Key="PackagePilotTextTertiaryBrush" Color="#8FFFFFFF" />
            <SolidColorBrush x:Key="PackagePilotAccentSoftBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.18" />
            <SolidColorBrush x:Key="PackagePilotSuccessBrush" Color="#FF6CCB5F" />
            <SolidColorBrush x:Key="PackagePilotSuccessSoftBrush" Color="#296CCB5F" />
            <SolidColorBrush x:Key="PackagePilotWarningBrush" Color="#FFFFC34A" />
            <SolidColorBrush x:Key="PackagePilotWarningSoftBrush" Color="#29FFC34A" />
            <SolidColorBrush x:Key="PackagePilotCriticalBrush" Color="#FFFF7B72" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="PackagePilotPageBrush" Color="Transparent" />
            <SolidColorBrush x:Key="PackagePilotSurfaceBrush" Color="#E6FFFFFF" />
            <SolidColorBrush x:Key="PackagePilotSurfaceSecondaryBrush" Color="#DDF5F6F8" />
            <SolidColorBrush x:Key="PackagePilotSurfaceTertiaryBrush" Color="#DDE9EAF0" />
            <SolidColorBrush x:Key="PackagePilotStrokeBrush" Color="#18000000" />
            <SolidColorBrush x:Key="PackagePilotStrokeStrongBrush" Color="#2B000000" />
            <SolidColorBrush x:Key="PackagePilotTextPrimaryBrush" Color="#E4000000" />
            <SolidColorBrush x:Key="PackagePilotTextSecondaryBrush" Color="#A3000000" />
            <SolidColorBrush x:Key="PackagePilotTextTertiaryBrush" Color="#A3000000" />
            <SolidColorBrush x:Key="PackagePilotAccentSoftBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.14" />
            <SolidColorBrush x:Key="PackagePilotSuccessBrush" Color="#FF187B31" />
            <SolidColorBrush x:Key="PackagePilotSuccessSoftBrush" Color="#19187B31" />
            <SolidColorBrush x:Key="PackagePilotWarningBrush" Color="#FF8A5B00" />
            <SolidColorBrush x:Key="PackagePilotWarningSoftBrush" Color="#198A5B00" />
            <SolidColorBrush x:Key="PackagePilotCriticalBrush" Color="#FFC42B1C" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="PackagePilotPageBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PackagePilotSurfaceBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PackagePilotSurfaceSecondaryBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PackagePilotSurfaceTertiaryBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PackagePilotStrokeBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PackagePilotStrokeStrongBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PackagePilotTextPrimaryBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PackagePilotTextSecondaryBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PackagePilotTextTertiaryBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PackagePilotAccentSoftBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="PackagePilotSuccessBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PackagePilotSuccessSoftBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PackagePilotWarningBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="PackagePilotWarningSoftBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="PackagePilotCriticalBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <FontFamily x:Key="PackagePilotContentFont">Segoe UI Variable Text</FontFamily>
    <FontFamily x:Key="PackagePilotDisplayFont">Segoe UI Variable Display</FontFamily>

    <Style x:Key="PackagePilotPageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PackagePilotDisplayFont}" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource PackagePilotTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="PackagePilotSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PackagePilotDisplayFont}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource PackagePilotTextPrimaryBrush}" />
    </Style>

    <Style x:Key="PackagePilotSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PackagePilotContentFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{ThemeResource PackagePilotTextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="PackagePilotCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PackagePilotContentFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource PackagePilotTextTertiaryBrush}" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="PackagePilotCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource PackagePilotSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource PackagePilotStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="PackagePilotSubtleCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource PackagePilotSurfaceSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource PackagePilotStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="PackagePilotRowCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource PackagePilotSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource PackagePilotStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,10" />
    </Style>

    <Style x:Key="PackagePilotPillStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource PackagePilotSurfaceTertiaryBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource PackagePilotStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="9,3" />
    </Style>

    <Style x:Key="PackagePilotIconTileStyle" TargetType="Border">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="Background" Value="{ThemeResource PackagePilotAccentSoftBrush}" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style x:Key="PackagePilotListViewStyle" TargetType="ListView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="IsItemClickEnabled" Value="True" />
        <Setter Property="SelectionMode" Value="Single" />
    </Style>

    <Style x:Key="PackagePilotIconButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

</ResourceDictionary>
