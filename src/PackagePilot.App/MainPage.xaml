<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PackagePilot.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PackagePilot.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource PackagePilotPageBrush}"
    Loaded="OnLoaded"
    mc:Ignorable="d">

    <NavigationView
        x:Name="ShellNavigation"
        AlwaysShowHeader="False"
        BackRequested="OnBackRequested"
        IsBackButtonVisible="Auto"
        IsPaneToggleButtonVisible="True"
        IsSettingsVisible="True"
        OpenPaneLength="224"
        PaneDisplayMode="Auto"
        SelectionChanged="OnNavigationSelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="DiscoverNavigationItem" Content="Discover" Tag="discover">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE721;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Installed" Tag="installed">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE896;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Updates" Tag="updates">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE895;" />
                </NavigationViewItem.Icon>
                <NavigationViewItem.InfoBadge>
                    <InfoBadge x:Name="UpdatesBadge" Value="-1" />
                </NavigationViewItem.InfoBadge>
            </NavigationViewItem>
            <NavigationViewItem Content="Activity" Tag="activity">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE823;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <InfoBar
                x:Name="HealthBanner"
                Margin="16,12,16,0"
                IsClosable="False"
                IsOpen="False"
                Severity="Warning" />

            <Frame
                x:Name="ContentFrame"
                Grid.Row="1"
                AutomationProperties.Name="Package Pilot content"
                IsNavigationStackEnabled="True"
                Navigated="OnContentNavigated" />

            <Border
                Grid.Row="2"
                Margin="12,0,12,12"
                Padding="12,9"
                Background="{ThemeResource PackagePilotSurfaceSecondaryBrush}"
                BorderBrush="{ThemeResource PackagePilotStrokeBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ProgressRing
                        x:Name="ActivityProgress"
                        Width="18"
                        Height="18"
                        AutomationProperties.Name="Package operation progress"
                        IsActive="False" />
                    <StackPanel Grid.Column="1" Spacing="1">
                        <TextBlock
                            x:Name="ActivitySummaryText"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Text="No active operations" />
                        <TextBlock
                            x:Name="StatusText"
                            Style="{StaticResource PackagePilotCaptionStyle}"
                            AutomationProperties.LiveSetting="Polite"
                            Text="Preparing Package Pilot…"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Button
                        Grid.Column="2"
                        AutomationProperties.Name="Open activity"
                        Click="OnOpenActivityClick"
                        Content="View activity" />
                </Grid>
            </Border>
        </Grid>
    </NavigationView>
</Page>
