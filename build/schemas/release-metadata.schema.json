{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:packagepilot:schema:release-metadata:2",
  "title": "Package Pilot release metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packageVersion",
    "architectures",
    "packageAsset",
    "releaseSequence",
    "tagName",
    "repository",
    "commitSha",
    "runId",
    "runNumber",
    "runAttempt",
    "artifactName",
    "workflowName",
    "generatedAtUtc"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2
    },
    "packageVersion": {
      "type": "string",
      "pattern": "^1[.]0[.](0|[1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])[.](0|[1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$"
    },
    "architectures": {
      "type": "array",
      "const": [
        "x64",
        "arm64"
      ]
    },
    "packageAsset": {
      "type": "string",
      "const": "PackagePilot.msixbundle"
    },
    "releaseSequence": {
      "type": "integer",
      "minimum": 5,
      "maximum": 4294967295
    },
    "tagName": {
      "type": "string",
      "pattern": "^v1[.]0[.]([5-9]|[1-9][0-9]{1,9})$"
    },
    "repository": {
      "type": "string",
      "const": "nativepapaya/package-pilot"
    },
    "commitSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "runId": {
      "type": "integer",
      "minimum": 1,
      "maximum": 18446744073709551615
    },
    "runNumber": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4294967291
    },
    "runAttempt": {
      "type": "integer",
      "minimum": 1,
      "maximum": 18446744073709551615
    },
    "artifactName": {
      "type": "string",
      "pattern": "^package-pilot-unsigned-[1-9][0-9]{0,19}-[1-9][0-9]{0,19}$"
    },
    "workflowName": {
      "type": "string",
      "const": "Release"
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9][.][0-9]{7}[+]00:00$"
    }
  }
}
